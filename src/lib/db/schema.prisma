generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          Int        @id @default(autoincrement())
  name        String     @unique
  password    String
  householdId Int?
  household   Household? @relation(fields: [householdId], references: [id])
  groceries   Grocery[]
  categories  Category[]
  documents   Document[]
}

model Household {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  secret         String?         @unique
  members        User[]
  Grocery        Grocery[]
  categories     Category[]
  recurringItems RecurringItem[]
  adjustments    Adjustment[]
  documents      Document[]
  docCategories  DocCategory[]
  keyInfo        KeyInfo[]
}

model Category {
  id          Int        @id @default(autoincrement())
  name        String
  household   Household? @relation(fields: [householdId], references: [id])
  householdId Int?
  User        User?      @relation(fields: [userId], references: [id])
  userId      Int?
  groceries   Grocery[]
  updatedAt   DateTime   @default(now()) @updatedAt

  @@unique([name, householdId])
  @@unique([name, userId])
}

model Grocery {
  id          Int        @id @default(autoincrement())
  name        String
  quantity    Int?       @default(1)
  bought      Boolean?   @default(false)
  household   Household? @relation(fields: [householdId], references: [id])
  householdId Int?
  User        User?      @relation(fields: [userId], references: [id])
  userId      Int?
  category    Category?  @relation(fields: [categoryId], references: [id])
  categoryId  Int?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @default(now()) @updatedAt

  @@unique([name, householdId])
  @@unique([name, userId])
}

enum RecurringKind {
  CONTRIBUTION
  EXPENSE
}

// A recurring monthly line item in the household pot: either a member's
// contribution (inleg) or a bill paid from the pot (uitgave). "Active" in a
// given month m means activeFrom <= m && (activeTo == null || activeTo >= m).
model RecurringItem {
  id            Int           @id @default(autoincrement())
  householdId   Int
  household     Household     @relation(fields: [householdId], references: [id])
  name          String
  kind          RecurringKind
  expectedCents Int
  activeFrom    String // "YYYY-MM", inclusive
  activeTo      String? // "YYYY-MM", inclusive; null = still active
  entries       MonthEntry[]

  @@unique([householdId, name, kind])
}

// Marks a RecurringItem as paid for a given month. Domain rule: entering an
// amount IS the act of paying — there's no separate "paid" flag.
model MonthEntry {
  id              Int           @id @default(autoincrement())
  recurringItemId Int
  recurringItem   RecurringItem @relation(fields: [recurringItemId], references: [id], onDelete: Cascade)
  month           String // "YYYY-MM"
  amountCents     Int
  paidAt          DateTime      @default(now())

  @@unique([recurringItemId, month])
}

// A one-off correction to the pot for a given month ("rechttrekken"), on top
// of the regular contributions/expenses.
model Adjustment {
  id          Int       @id @default(autoincrement())
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  month       String
  amountCents Int // positive adds to the pot, negative removes
  note        String?
  createdAt   DateTime  @default(now())
}

// A user-created, household-scoped grouping for documents (mirrors the
// grocery Category pattern). Deleting one moves its documents to
// uncategorized ("Overig") via onDelete: SetNull.
model DocCategory {
  id          Int        @id @default(autoincrement())
  name        String
  householdId Int
  household   Household  @relation(fields: [householdId], references: [id])
  documents   Document[]

  @@unique([name, householdId])
}

// A file in the household's document vault. The actual bytes live in
// whichever FileStorage backend is active (src/lib/storage/) — this row is
// just the pointer + metadata. storageKey is server-generated and never
// client-supplied.
model Document {
  id           Int          @id @default(autoincrement())
  householdId  Int
  household    Household    @relation(fields: [householdId], references: [id])
  name         String // display name, 1-60 chars
  categoryId   Int? // null = uncategorized ("Overig")
  category     DocCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  storageKey   String       @unique
  contentType  String
  sizeBytes    Int
  uploadedById Int?
  uploadedBy   User?        @relation(fields: [uploadedById], references: [id])
  createdAt    DateTime     @default(now())
}

// A household-wide label/value pair for quick-reference info (e.g. "WiFi
// wachtwoord"). Upserted by label, so label doubles as the natural key.
model KeyInfo {
  id          Int       @id @default(autoincrement())
  householdId Int
  household   Household @relation(fields: [householdId], references: [id])
  label       String // e.g. "WiFi wachtwoord"
  value       String

  @@unique([householdId, label])
}
